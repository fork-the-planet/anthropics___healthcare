{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    // typecheck only — the shipped artifact is the bun bundle (../fhir.js),
    // which inlines the shared decoders from skills/doc-extract
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "fhir"],
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*", "../shared/**/*"],
  "exclude": ["src/**/*.test.ts"]
}
