{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    // typecheck only — src/*.mjs is what ships and what node runs, unbuilt
    "noEmit": true,
    "strict": true,
    // the server and shared/ ship as plain .mjs with JSDoc types; without
    // allowJs+checkJs they typecheck as any and drift goes unseen until runtime
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "fhir"],
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src/**/*", "../shared/**/*.mjs"],
  "exclude": ["src/**/*.test.ts"]
}
